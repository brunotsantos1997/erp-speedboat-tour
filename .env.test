# Test environment variables - ISOLADO DE PRODUÇÃO
# Configuração específica para testes unitários e integração

# Firebase Test Project (separado do projeto de produção)
VITE_FIREBASE_TEST_PROJECT_ID=erp-speedboat-test
VITE_FIREBASE_TEST_API_KEY=test-api-key
VITE_FIREBASE_TEST_AUTH_DOMAIN=test.firebaseapp.com
VITE_FIREBASE_TEST_DATABASE_URL=https://erp-speedboat-test.firebaseio.com
VITE_FIREBASE_TEST_STORAGE_BUCKET=erp-speedboat-test.appspot.com
VITE_FIREBASE_TEST_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_TEST_APP_ID=1:123456789:web:abcdef

# Test Database Configuration
VITE_TEST_DB_URL=http://localhost:8080/emulator
VITE_TEST_DB_EMULATOR=true

# Mock Configuration
VITE_TEST_MOCK_FIRESTORE=true
VITE_TEST_MOCK_AUTH=true
VITE_TEST_MOCK_STORAGE=true

# Test Users (sintéticos, não reais)
VITE_TEST_EMAIL=test-user@example.com
VITE_TEST_PASSWORD=TestPassword123!
VITE_TEST_ADMIN_EMAIL=test-admin@example.com
VITE_TEST_ADMIN_PASSWORD=AdminPassword123!

# Test Settings
VITE_TEST_TIMEOUT=30000
VITE_TEST_RETRY_ATTEMPTS=3
VITE_TEST_LOG_LEVEL=debug

# Network Mocking
VITE_TEST_MOCK_NETWORK_LATENCY=100
VITE_TEST_MOCK_OFFLINE_MODE=false

# Coverage Settings
VITE_COVERAGE_THRESHOLD=60
VITE_COVERAGE_REPORTERS=text,html,json
